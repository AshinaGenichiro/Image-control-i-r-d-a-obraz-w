<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp5.NewPage1"
             Title="NewPage1">
    <VerticalStackLayout>
        <Image
    Source="dotnet_bot.png"
    HeightRequest="200"
    Aspect="AspectFit"/>

        <Image HeightRequest="250"
               x:Name="mainImage">
            <Image.Source>
                <UriImageSource Uri="https://content-hub.imgix.net/3DCl3TvYPXzbjcbdlqMras/a9fe7b8e89364ab1be02bd28b61683ac/Porsche_Cayenne_Turbo_GT_drives_through_city_streets_in_scene_from_Resident_Evil_Requiem_hero_desktop.jpg?w=2064"
        CacheValidity="10:00:00:00"
                            />
            </Image.Source>
        </Image>
        <Image
            HeightRequest="200"
            Source="https://i.redd.it/s9loa3bdfmbf1.gif"
               IsAnimationPlaying="True"/>
        <ImageButton
            Source="dotnet_bot.png"
            HeightRequest="50"
            Clicked="changeMainImgAspect"/>
        <Label
            x:Name="aspectLabel"
            Text="Aktualny tryb wyświetlania to AspectFit "/>
        <Label
          Text="{Binding Source={x:Reference mainImage}, Path=IsLoading}"
            />
    </VerticalStackLayout>
</ContentPage>